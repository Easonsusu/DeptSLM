# Copy this file to .env and replace this value with the path printed by
# scripts/setup_google_drive_storage.sh. DeptSLM must not write persistent
# runtime data inside the repository.
DEPTSLM_DATA_DIR="/absolute/path/to/GoogleDrive/My Drive/DeptSLM"
DEPTSLM_DOCUMENT_MAX_BYTES="26214400"
DEPTSLM_DEPARTMENT_DOCUMENT_QUOTA_BYTES="1073741824"

# Phase 5 extraction worker limits. The lease must exceed the timeout by at
# least 30 seconds; overlap must not exceed half the chunk size.
DEPTSLM_EXTRACTION_TIMEOUT_SECONDS="120"
DEPTSLM_MAX_EXTRACTED_BYTES="104857600"
DEPTSLM_MAX_PDF_PAGES="1000"
DEPTSLM_CHUNK_MAX_CHARS="1200"
DEPTSLM_CHUNK_OVERLAP_CHARS="200"
DEPTSLM_MAX_CHUNKS_PER_DOCUMENT="100000"
DEPTSLM_EXTRACTION_LEASE_SECONDS="300"
DEPTSLM_WORKER_POLL_SECONDS="5"
DEPTSLM_DEPARTMENT_EXTRACTED_QUOTA_BYTES="4294967296"

# This Compose-internal URL uses the service hostname "postgres". Commands run
# directly on the host must instead use a host-accessible URL with localhost.
DATABASE_URL="postgresql+psycopg://deptslm:deptslm@postgres:5432/deptslm"
API_PORT=8000
WEB_PORT=3000
ENVIRONMENT="development"

# Development/test authentication only. HS256 requires ENVIRONMENT to be one of
# local, development, dev, or test. Generate a local uncommitted secret with:
# python -c 'import secrets; print(secrets.token_urlsafe(48))'
# Keep the generated value only in the untracked local .env file. Compose passes
# these authentication settings only to the API container.
DEPTSLM_AUTH_MODE="disabled"
DEPTSLM_AUTH_ISSUER="https://issuer.example.invalid"
DEPTSLM_AUTH_AUDIENCE="deptslm-local"
DEPTSLM_AUTH_SECRET=""

# Phase 6 indexing only. Generate a long local API key and keep it only in the
# untracked .env file. The model preparation command may additionally read an
# untracked HF_TOKEN, but ordinary workers never receive it or use the network.
DEPTSLM_QDRANT_URL="http://qdrant:6333"
DEPTSLM_QDRANT_API_KEY=""
DEPTSLM_QDRANT_COLLECTION="deptslm_chunks_qwen3_0_6b_1024_v1"
DEPTSLM_QDRANT_TIMEOUT_SECONDS="30"
DEPTSLM_VECTOR_INDEX_LEASE_SECONDS="300"
DEPTSLM_VECTOR_INDEX_POLL_SECONDS="5"
DEPTSLM_EMBEDDING_BATCH_SIZE="8"
DEPTSLM_EMBEDDING_MAX_BATCH_CHARS="8192"
DEPTSLM_EMBEDDING_TIMEOUT_SECONDS="120"
DEPTSLM_EMBEDDING_MODEL_REVISION="d23109d65ca9fdf61eef614209744716f337f50f"
DEPTSLM_EMBEDDING_PROVIDER="real"
