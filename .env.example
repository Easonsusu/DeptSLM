# Copy this file to .env and replace this value with the path printed by
# scripts/setup_google_drive_storage.sh. DeptSLM must not write persistent
# runtime data inside the repository.
DEPTSLM_DATA_DIR="/absolute/path/to/GoogleDrive/My Drive/DeptSLM"

DATABASE_URL="postgresql://deptslm:deptslm@postgres:5432/deptslm"
QDRANT_URL="http://qdrant:6333"
API_PORT=8000
WEB_PORT=3000
ENVIRONMENT="development"

# Development/test authentication only. Replace the placeholder locally and
# never use HS256 mode in production. Protected routes fail closed when disabled
# or when any required HS256 setting is missing.
DEPTSLM_AUTH_MODE="disabled"
DEPTSLM_AUTH_ISSUER="https://issuer.example.invalid"
DEPTSLM_AUTH_AUDIENCE="deptslm-local"
DEPTSLM_AUTH_SECRET="replace-with-a-local-development-secret"
