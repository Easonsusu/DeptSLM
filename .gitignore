# DeptSLM runtime data. Deny these directory names recursively so an accidental
# write below an app, service, package, or data directory cannot be staged.
# data/sample_docs and data/eval_sets intentionally remain source-controlled for
# small, reviewed synthetic fixtures.
**/runtime/
**/.runtime/
**/uploads/
**/extracted_text/
**/vector_snapshots/
**/training_datasets/
**/adapters/
**/model_cache/
**/eval_results/
**/logs/
**/exports/
**/service_state/
**/qdrant_storage/
**/postgres-data/
/postgres/

